---
import { ArrowRight, Search, ShoppingBag, SlidersHorizontal } from 'lucide-astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import CategoryCard from '@/components/CategoryCard.astro';
import GuideCard from '@/components/GuideCard.astro';
import ProductCard from '@/components/ProductCard.astro';
import { categories, site } from '@/data/site';
import { products } from '@/data/products';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
const featuredGuides = guides.filter((guide) => guide.data.featured).slice(0, 3);
const hotKeywords = ['显示器', '扩展坞', '小夜灯', '路由器', '人体工学椅', 'NAS'];
const initialProducts = products.slice(0, 24);
const categoryCards = categories.map((category) => ({
  ...category,
  productCount: products.filter((product) => product.category === category.slug).length
}));
const bestDeal = products.reduce((best, product) => {
  const saved = product.jdPrice - product.finalPrice;
  const bestSaved = best.jdPrice - best.finalPrice;
  return saved > bestSaved ? product : best;
}, products[0]);
---

<BaseLayout title="京东好物搜索与优惠清单" description={site.description}>
  <section class="market-hero">
    <div class="container market-hero-inner">
      <div class="market-copy">
        <p class="eyebrow"><ShoppingBag size={18} aria-hidden="true" /> 京东好物清单</p>
        <h1>搜商品，看价格，直接去京东</h1>
        <p>精选数码电器、电脑配件、家居办公和生活小物，按到手价、优惠力度和使用场景快速筛选。</p>
      </div>

      <div class="market-search-panel">
        <form class="search-form" id="productSearchForm" role="search">
          <label class="sr-only" for="productSearch">搜索商品</label>
          <Search size={20} aria-hidden="true" />
          <input id="productSearch" name="q" type="search" placeholder="搜索商品、品牌、规格" autocomplete="off" />
          <button class="button" type="submit">搜索</button>
        </form>
        <div class="hot-searches" aria-label="热门搜索">
          {hotKeywords.map((keyword) => <button type="button" data-search-term={keyword}>{keyword}</button>)}
        </div>
        <div class="market-stats" aria-label="商品概览">
          <span><strong>{products.length}</strong> 精选商品</span>
          <span><strong>{categories.length}</strong> 个分类</span>
          <span><strong>¥{Math.round(bestDeal.jdPrice - bestDeal.finalPrice)}</strong> 最高可省</span>
          <span><strong>持续</strong> 更新</span>
        </div>
      </div>
    </div>
  </section>

  <section class="category-rail-section">
    <div class="container">
      <div class="category-rail" aria-label="快捷分类">
        <button class="category-pill active" type="button" data-filter-category="all">全部</button>
        {categories.map((category) => <button class="category-pill" type="button" data-filter-category={category.slug}>{category.name}</button>)}
      </div>
    </div>
  </section>

  <section id="products" class="section product-market">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>商品列表</h2>
          <p id="resultCount">{products.length} 件商品</p>
        </div>
        <div class="sort-tabs" aria-label="商品排序">
          <span><SlidersHorizontal size={16} aria-hidden="true" /> 排序</span>
          <button class="active" type="button" data-sort="recommend">推荐</button>
          <button type="button" data-sort="price-asc">低价</button>
          <button type="button" data-sort="save-desc">优惠</button>
        </div>
      </div>
      <div class="grid three product-grid" id="productGrid" data-total-products={products.length} data-initial-products={initialProducts.length}>
        {initialProducts.map((product) => <ProductCard product={product} />)}
      </div>
      <div class="empty-state" id="emptyProducts" hidden>
        <h3>没找到匹配商品</h3>
        <p>换个关键词，或查看全部分类。</p>
        <button class="button" type="button" id="resetSearch">查看全部商品</button>
      </div>
      <div class="load-more-row">
        <button class="button secondary-light" type="button" id="loadMoreProducts" hidden>加载更多</button>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>商品分类</h2>
          <p>按大类浏览当前商品清单，后续可以继续扩展更多品牌和型号。</p>
        </div>
        <a class="text-link" href="/categories/">全部分类 <ArrowRight size={16} aria-hidden="true" /></a>
      </div>
      <div class="grid three">
        {categoryCards.map((category) => <CategoryCard {...category} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>选购指南</h2>
          <p>用短指南解释怎么选，再回到对应商品清单。</p>
        </div>
        <a class="text-link" href="/guides/">全部指南 <ArrowRight size={16} aria-hidden="true" /></a>
      </div>
      <div class="grid three">
        {featuredGuides.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </div>
  </section>

  <script>
    const grid = document.getElementById('productGrid');
    const searchForm = document.getElementById('productSearchForm');
    const searchInput = document.getElementById('productSearch');
    const resultCount = document.getElementById('resultCount');
    const emptyProducts = document.getElementById('emptyProducts');
    const resetSearch = document.getElementById('resetSearch');
    const categoryButtons = Array.from(document.querySelectorAll('[data-filter-category]'));
    const sortButtons = Array.from(document.querySelectorAll('[data-sort]'));
    const hotSearchButtons = Array.from(document.querySelectorAll('[data-search-term]'));
    let cards = Array.from(document.querySelectorAll('#productGrid [data-product-card]'));

    let currentCategory = 'all';
    let currentSort = 'recommend';
    let currentOffset = cards.length;
    let currentTotal = Number(grid?.dataset.totalProducts || cards.length);
    let currentHasMore = currentOffset < currentTotal;
    let isApiMode = false;
    const pageSize = 24;
    const apiBase = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
      ? 'http://127.0.0.1:8787'
      : '';

    const normalize = (value) => String(value || '').trim().toLowerCase();
    const money = (value) => Number(value || 0).toLocaleString('zh-CN', {
      minimumFractionDigits: Number.isInteger(Number(value || 0)) ? 0 : 2,
      maximumFractionDigits: 2
    });

    const escapeHtml = (value) => String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');

    const getSearchText = (product) => [
      product.name,
      product.jdTitle,
      product.summary,
      product.bestFor,
      product.typeLabel,
      product.category,
      ...(product.specs || []),
      ...(product.tags || [])
    ].join(' ').toLowerCase();

    const renderProductCard = (product) => {
      const savedAmount = Math.max(0, Number(product.jdPrice || 0) - Number(product.finalPrice || 0));
      const detailUrl = `/products/${encodeURIComponent(product.id)}/`;
      const purchaseUrl = `/go/${encodeURIComponent(product.id)}/`;
      const searchText = getSearchText(product);
      const specs = Array.isArray(product.specs) ? product.specs : [];

      return `
        <article
          class="product-card ${product.image ? '' : 'illustrated'}"
          data-product-card
          data-product-id="${escapeHtml(product.id)}"
          data-category="${escapeHtml(product.category)}"
          data-price="${escapeHtml(product.finalPrice)}"
          data-save="${escapeHtml(savedAmount)}"
          data-search="${escapeHtml(searchText)}"
        >
          <a class="product-visual" href="${detailUrl}" aria-label="查看 ${escapeHtml(product.name)} 详情">
            <span class="product-source-badge">京东</span>
            ${
              product.image
                ? `<img src="${escapeHtml(product.image)}" alt="${escapeHtml(product.jdTitle)}" loading="lazy" />`
                : `<div class="product-placeholder"><span>${escapeHtml(product.typeLabel || '京东商品')}</span></div>`
            }
          </a>
          <div class="product-body">
            <div class="product-kicker">
              <span>${escapeHtml(product.typeLabel || '京东商品')}</span>
              <span>${product.jdSku ? `SKU ${escapeHtml(product.jdSku)}` : '京东活动页'}</span>
            </div>
            <h3 class="product-title"><a href="${detailUrl}">${escapeHtml(product.name)}</a></h3>
            <p class="product-jd-title">${escapeHtml(product.jdTitle)}</p>
            <div class="product-price-panel">
              <div>
                <span class="price-label">到手价</span>
                <strong class="price-value">¥${money(product.finalPrice)}</strong>
              </div>
              ${savedAmount > 0 ? `<span class="save-badge">省 ¥${money(savedAmount)}</span>` : ''}
            </div>
            <div class="market-price">
              <span>京东价</span>
              <del>¥${money(product.jdPrice)}</del>
            </div>
            <p class="product-summary">${escapeHtml(product.summary)}</p>
            <div class="spec-row" aria-label="关键规格">
              ${specs.map((spec) => `<span class="spec">${escapeHtml(spec)}</span>`).join('')}
            </div>
            <div class="product-best-for">
              <span>适合</span>
              <strong>${escapeHtml(product.bestFor)}</strong>
            </div>
            <a class="button product-link" href="${purchaseUrl}" rel="sponsored nofollow" target="_blank">
              <span class="product-link-full">去京东抢购</span>
              <span class="product-link-short">购买</span>
            </a>
          </div>
        </article>
      `;
    };

    const refreshCards = () => {
      cards = Array.from(document.querySelectorAll('#productGrid [data-product-card]'));
      observeProductCards();
    };

    const updateLoadMore = () => {
      const loadMore = document.getElementById('loadMoreProducts');
      if (loadMore) {
        loadMore.hidden = !currentHasMore;
      }
    };

    const fetchProducts = async ({ offset = 0 } = {}) => {
      const params = new URLSearchParams();
      const query = searchInput ? searchInput.value.trim() : '';
      if (query) params.set('q', query);
      if (currentCategory !== 'all') params.set('category', currentCategory);
      if (currentSort !== 'recommend') params.set('sort', currentSort);
      params.set('offset', String(offset));
      params.set('limit', String(pageSize));

      const response = await fetch(`${apiBase}/api/products/search?${params.toString()}`);
      const payload = await response.json();
      if (!response.ok || payload.ok === false) {
        throw new Error(payload.error || '商品搜索接口不可用');
      }
      return payload;
    };

    const renderApiProducts = (payload, { append = false } = {}) => {
      if (!grid) return;
      const html = (payload.products || []).map(renderProductCard).join('');
      append ? grid.insertAdjacentHTML('beforeend', html) : grid.innerHTML = html;
      currentTotal = payload.total || 0;
      currentOffset = (payload.offset || 0) + (payload.products || []).length;
      currentHasMore = Boolean(payload.hasMore);
      isApiMode = true;
      refreshCards();

      if (resultCount) {
        const query = searchInput ? searchInput.value.trim() : '';
        resultCount.textContent = query ? `找到 ${currentTotal} 件商品` : `${currentTotal} 件商品`;
      }

      if (emptyProducts) {
        emptyProducts.hidden = currentTotal > 0;
      }
      updateLoadMore();
    };

    const setActiveButton = (buttons, activeValue, attribute) => {
      buttons.forEach((button) => {
        const isActive = button.getAttribute(attribute) === activeValue;
        button.classList.toggle('active', isActive);
        button.setAttribute('aria-pressed', String(isActive));
      });
    };

    const updateUrl = () => {
      const params = new URLSearchParams(window.location.search);
      const query = searchInput ? searchInput.value.trim() : '';

      query ? params.set('q', query) : params.delete('q');
      currentCategory !== 'all' ? params.set('category', currentCategory) : params.delete('category');
      currentSort !== 'recommend' ? params.set('sort', currentSort) : params.delete('sort');

      const queryString = params.toString();
      const nextUrl = `${window.location.pathname}${queryString ? `?${queryString}` : ''}#products`;
      window.history.replaceState({}, '', nextUrl);
    };

    const sortCards = (items) => {
      return [...items].sort((a, b) => {
        if (currentSort === 'price-asc') {
          return Number(a.dataset.price || 0) - Number(b.dataset.price || 0);
        }

        if (currentSort === 'save-desc') {
          return Number(b.dataset.save || 0) - Number(a.dataset.save || 0);
        }

        return cards.indexOf(a) - cards.indexOf(b);
      });
    };

    const applyFilters = ({ shouldUpdateUrl = false, shouldScroll = false } = {}) => {
      const query = normalize(searchInput ? searchInput.value : '');
      const terms = query.split(/\s+/).filter(Boolean);
      const matched = cards.filter((card) => {
        const matchesCategory = currentCategory === 'all' || card.dataset.category === currentCategory;
        const searchText = normalize(card.dataset.search);
        const matchesQuery = terms.every((term) => searchText.includes(term));
        return matchesCategory && matchesQuery;
      });
      const sorted = sortCards(matched);

      cards.forEach((card) => {
        const isVisible = matched.includes(card);
        card.hidden = !isVisible;
        card.classList.toggle('is-hidden', !isVisible);
      });

      sorted.forEach((card) => grid?.appendChild(card));

      if (resultCount) {
        const label = query ? `找到 ${matched.length} 件商品` : `${matched.length} 件商品`;
        resultCount.textContent = label;
      }

      if (emptyProducts) {
        emptyProducts.hidden = matched.length > 0;
      }

      currentHasMore = false;
      updateLoadMore();

      if (shouldUpdateUrl) {
        updateUrl();
      }

      if (shouldScroll) {
        document.getElementById('products')?.scrollIntoView({ block: 'start' });
      }
    };

    const applyApiFilters = async (options = {}) => {
      try {
        const payload = await fetchProducts({ offset: 0 });
        renderApiProducts(payload);
        if (options.shouldUpdateUrl) updateUrl();
        if (options.shouldScroll) document.getElementById('products')?.scrollIntoView({ block: 'start' });
      } catch {
        isApiMode = false;
        applyFilters(options);
      }
    };

    searchForm?.addEventListener('submit', (event) => {
      event.preventDefault();
      applyApiFilters({ shouldUpdateUrl: true, shouldScroll: true });
    });

    searchInput?.addEventListener('input', () => {
      applyFilters();
    });

    categoryButtons.forEach((button) => {
      button.addEventListener('click', () => {
        currentCategory = button.getAttribute('data-filter-category') || 'all';
        setActiveButton(categoryButtons, currentCategory, 'data-filter-category');
        applyApiFilters({ shouldUpdateUrl: true, shouldScroll: true });
      });
    });

    sortButtons.forEach((button) => {
      button.addEventListener('click', () => {
        currentSort = button.getAttribute('data-sort') || 'recommend';
        setActiveButton(sortButtons, currentSort, 'data-sort');
        applyApiFilters({ shouldUpdateUrl: true });
      });
    });

    hotSearchButtons.forEach((button) => {
      button.addEventListener('click', () => {
        if (searchInput) {
          searchInput.value = button.getAttribute('data-search-term') || '';
        }
        applyApiFilters({ shouldUpdateUrl: true, shouldScroll: true });
      });
    });

    resetSearch?.addEventListener('click', () => {
      if (searchInput) {
        searchInput.value = '';
      }
      currentCategory = 'all';
      currentSort = 'recommend';
      setActiveButton(categoryButtons, currentCategory, 'data-filter-category');
      setActiveButton(sortButtons, currentSort, 'data-sort');
      applyApiFilters({ shouldUpdateUrl: true });
    });

    document.getElementById('loadMoreProducts')?.addEventListener('click', async () => {
      try {
        const payload = await fetchProducts({ offset: currentOffset });
        renderApiProducts(payload, { append: true });
      } catch {
        currentHasMore = false;
        updateLoadMore();
      }
    });

    const exposedProductIds = new Set();
    const sendExposure = (productId) => {
      if (!productId || exposedProductIds.has(productId)) return;
      exposedProductIds.add(productId);
      const payload = JSON.stringify({
        productId,
        referrer: document.referrer,
        userAgent: navigator.userAgent
      });

      try {
        if (navigator.sendBeacon) {
          navigator.sendBeacon(`${apiBase}/api/exposures`, payload);
        } else {
          fetch(`${apiBase}/api/exposures`, {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: payload,
            keepalive: true
          });
        }
      } catch {}
    };

    const observer = 'IntersectionObserver' in window
      ? new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              sendExposure(entry.target.dataset.productId);
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.35 })
      : null;

    function observeProductCards() {
      if (!observer) return;
      document.querySelectorAll('#productGrid [data-product-card]').forEach((card) => {
        if (!card.dataset.exposureObserved) {
          card.dataset.exposureObserved = 'true';
          observer.observe(card);
        }
      });
    }

    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get('q');
    const initialCategory = params.get('category');
    const initialSort = params.get('sort');

    if (searchInput && initialQuery) {
      searchInput.value = initialQuery;
    }

    if (initialCategory && categoryButtons.some((button) => button.getAttribute('data-filter-category') === initialCategory)) {
      currentCategory = initialCategory;
    }

    if (initialSort && sortButtons.some((button) => button.getAttribute('data-sort') === initialSort)) {
      currentSort = initialSort;
    }

    setActiveButton(categoryButtons, currentCategory, 'data-filter-category');
    setActiveButton(sortButtons, currentSort, 'data-sort');
    applyFilters();
    updateLoadMore();
    observeProductCards();
  </script>
</BaseLayout>
