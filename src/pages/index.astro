---
import { ArrowRight, Search, ShoppingBag, SlidersHorizontal } from 'lucide-astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import CategoryCard from '@/components/CategoryCard.astro';
import GuideCard from '@/components/GuideCard.astro';
import ProductCard from '@/components/ProductCard.astro';
import { categories, site } from '@/data/site';
import { products } from '@/data/products';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
const featuredGuides = guides.filter((guide) => guide.data.featured).slice(0, 3);
const hotKeywords = ['显示器', '扩展坞', '小夜灯', '路由器', '人体工学椅', 'NAS'];
const categoryCards = categories.map((category) => ({
  ...category,
  productCount: products.filter((product) => product.category === category.slug).length
}));
const bestDeal = products.reduce((best, product) => {
  const saved = product.jdPrice - product.finalPrice;
  const bestSaved = best.jdPrice - best.finalPrice;
  return saved > bestSaved ? product : best;
}, products[0]);
---

<BaseLayout title="京东好物搜索与优惠清单" description={site.description}>
  <section class="market-hero">
    <div class="container market-hero-inner">
      <div class="market-copy">
        <p class="eyebrow"><ShoppingBag size={18} aria-hidden="true" /> 京东好物清单</p>
        <h1>搜商品，看价格，直接去京东</h1>
        <p>精选数码电器、电脑配件、家居办公和生活小物，按到手价、优惠力度和使用场景快速筛选。</p>
      </div>

      <div class="market-search-panel">
        <form class="search-form" id="productSearchForm" role="search">
          <label class="sr-only" for="productSearch">搜索商品</label>
          <Search size={20} aria-hidden="true" />
          <input id="productSearch" name="q" type="search" placeholder="搜索商品、品牌、规格" autocomplete="off" />
          <button class="button" type="submit">搜索</button>
        </form>
        <div class="hot-searches" aria-label="热门搜索">
          {hotKeywords.map((keyword) => <button type="button" data-search-term={keyword}>{keyword}</button>)}
        </div>
        <div class="market-stats" aria-label="商品概览">
          <span><strong>{products.length}</strong> 精选商品</span>
          <span><strong>{categories.length}</strong> 个分类</span>
          <span><strong>¥{Math.round(bestDeal.jdPrice - bestDeal.finalPrice)}</strong> 最高可省</span>
          <span><strong>持续</strong> 更新</span>
        </div>
      </div>
    </div>
  </section>

  <section class="category-rail-section">
    <div class="container">
      <div class="category-rail" aria-label="快捷分类">
        <button class="category-pill active" type="button" data-filter-category="all">全部</button>
        {categories.map((category) => <button class="category-pill" type="button" data-filter-category={category.slug}>{category.name}</button>)}
      </div>
    </div>
  </section>

  <section id="products" class="section product-market">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>商品列表</h2>
          <p id="resultCount">{products.length} 件商品</p>
        </div>
        <div class="sort-tabs" aria-label="商品排序">
          <span><SlidersHorizontal size={16} aria-hidden="true" /> 排序</span>
          <button class="active" type="button" data-sort="recommend">推荐</button>
          <button type="button" data-sort="price-asc">低价</button>
          <button type="button" data-sort="save-desc">优惠</button>
        </div>
      </div>
      <div class="grid three product-grid" id="productGrid">
        {products.map((product) => <ProductCard product={product} />)}
      </div>
      <div class="empty-state" id="emptyProducts" hidden>
        <h3>没找到匹配商品</h3>
        <p>换个关键词，或查看全部分类。</p>
        <button class="button" type="button" id="resetSearch">查看全部商品</button>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>商品分类</h2>
          <p>按大类浏览当前商品清单，后续可以继续扩展更多品牌和型号。</p>
        </div>
        <a class="text-link" href="/categories/">全部分类 <ArrowRight size={16} aria-hidden="true" /></a>
      </div>
      <div class="grid three">
        {categoryCards.map((category) => <CategoryCard {...category} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2>选购指南</h2>
          <p>用短指南解释怎么选，再回到对应商品清单。</p>
        </div>
        <a class="text-link" href="/guides/">全部指南 <ArrowRight size={16} aria-hidden="true" /></a>
      </div>
      <div class="grid three">
        {featuredGuides.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </div>
  </section>

  <script>
    const grid = document.getElementById('productGrid');
    const searchForm = document.getElementById('productSearchForm');
    const searchInput = document.getElementById('productSearch');
    const resultCount = document.getElementById('resultCount');
    const emptyProducts = document.getElementById('emptyProducts');
    const resetSearch = document.getElementById('resetSearch');
    const categoryButtons = Array.from(document.querySelectorAll('[data-filter-category]'));
    const sortButtons = Array.from(document.querySelectorAll('[data-sort]'));
    const hotSearchButtons = Array.from(document.querySelectorAll('[data-search-term]'));
    const cards = Array.from(document.querySelectorAll('#productGrid [data-product-card]'));

    let currentCategory = 'all';
    let currentSort = 'recommend';

    const normalize = (value) => String(value || '').trim().toLowerCase();

    const setActiveButton = (buttons, activeValue, attribute) => {
      buttons.forEach((button) => {
        const isActive = button.getAttribute(attribute) === activeValue;
        button.classList.toggle('active', isActive);
        button.setAttribute('aria-pressed', String(isActive));
      });
    };

    const updateUrl = () => {
      const params = new URLSearchParams(window.location.search);
      const query = searchInput ? searchInput.value.trim() : '';

      query ? params.set('q', query) : params.delete('q');
      currentCategory !== 'all' ? params.set('category', currentCategory) : params.delete('category');
      currentSort !== 'recommend' ? params.set('sort', currentSort) : params.delete('sort');

      const queryString = params.toString();
      const nextUrl = `${window.location.pathname}${queryString ? `?${queryString}` : ''}#products`;
      window.history.replaceState({}, '', nextUrl);
    };

    const sortCards = (items) => {
      return [...items].sort((a, b) => {
        if (currentSort === 'price-asc') {
          return Number(a.dataset.price || 0) - Number(b.dataset.price || 0);
        }

        if (currentSort === 'save-desc') {
          return Number(b.dataset.save || 0) - Number(a.dataset.save || 0);
        }

        return cards.indexOf(a) - cards.indexOf(b);
      });
    };

    const applyFilters = ({ shouldUpdateUrl = false, shouldScroll = false } = {}) => {
      const query = normalize(searchInput ? searchInput.value : '');
      const terms = query.split(/\s+/).filter(Boolean);
      const matched = cards.filter((card) => {
        const matchesCategory = currentCategory === 'all' || card.dataset.category === currentCategory;
        const searchText = normalize(card.dataset.search);
        const matchesQuery = terms.every((term) => searchText.includes(term));
        return matchesCategory && matchesQuery;
      });
      const sorted = sortCards(matched);

      cards.forEach((card) => {
        const isVisible = matched.includes(card);
        card.hidden = !isVisible;
        card.classList.toggle('is-hidden', !isVisible);
      });

      sorted.forEach((card) => grid?.appendChild(card));

      if (resultCount) {
        const label = query ? `找到 ${matched.length} 件商品` : `${matched.length} 件商品`;
        resultCount.textContent = label;
      }

      if (emptyProducts) {
        emptyProducts.hidden = matched.length > 0;
      }

      if (shouldUpdateUrl) {
        updateUrl();
      }

      if (shouldScroll) {
        document.getElementById('products')?.scrollIntoView({ block: 'start' });
      }
    };

    searchForm?.addEventListener('submit', (event) => {
      event.preventDefault();
      applyFilters({ shouldUpdateUrl: true, shouldScroll: true });
    });

    searchInput?.addEventListener('input', () => {
      applyFilters();
    });

    categoryButtons.forEach((button) => {
      button.addEventListener('click', () => {
        currentCategory = button.getAttribute('data-filter-category') || 'all';
        setActiveButton(categoryButtons, currentCategory, 'data-filter-category');
        applyFilters({ shouldUpdateUrl: true, shouldScroll: true });
      });
    });

    sortButtons.forEach((button) => {
      button.addEventListener('click', () => {
        currentSort = button.getAttribute('data-sort') || 'recommend';
        setActiveButton(sortButtons, currentSort, 'data-sort');
        applyFilters({ shouldUpdateUrl: true });
      });
    });

    hotSearchButtons.forEach((button) => {
      button.addEventListener('click', () => {
        if (searchInput) {
          searchInput.value = button.getAttribute('data-search-term') || '';
        }
        applyFilters({ shouldUpdateUrl: true, shouldScroll: true });
      });
    });

    resetSearch?.addEventListener('click', () => {
      if (searchInput) {
        searchInput.value = '';
      }
      currentCategory = 'all';
      currentSort = 'recommend';
      setActiveButton(categoryButtons, currentCategory, 'data-filter-category');
      setActiveButton(sortButtons, currentSort, 'data-sort');
      applyFilters({ shouldUpdateUrl: true });
    });

    const params = new URLSearchParams(window.location.search);
    const initialQuery = params.get('q');
    const initialCategory = params.get('category');
    const initialSort = params.get('sort');

    if (searchInput && initialQuery) {
      searchInput.value = initialQuery;
    }

    if (initialCategory && categoryButtons.some((button) => button.getAttribute('data-filter-category') === initialCategory)) {
      currentCategory = initialCategory;
    }

    if (initialSort && sortButtons.some((button) => button.getAttribute('data-sort') === initialSort)) {
      currentSort = initialSort;
    }

    setActiveButton(categoryButtons, currentCategory, 'data-filter-category');
    setActiveButton(sortButtons, currentSort, 'data-sort');
    applyFilters();
  </script>
</BaseLayout>
