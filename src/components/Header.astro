---
import { Search, ShoppingBag } from 'lucide-astro';
import { site } from '@/data/site';

const pathname = Astro.url.pathname;

const links = [
  { href: '/', label: '首页' },
  { href: '/categories/', label: '商品分类' },
  { href: '/guides/', label: '选购指南' },
  { href: '/tools/', label: '工具' },
  { href: '/about/', label: '关于' }
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label={site.name}>
      <span class="brand-mark"><ShoppingBag size={19} aria-hidden="true" /></span>
      <span class="brand-text">{site.name}</span>
    </a>
    <form class="header-search" id="headerSearchForm" role="search">
      <label class="sr-only" for="headerSearchInput">搜索商品</label>
      <Search size={17} aria-hidden="true" />
      <input id="headerSearchInput" name="q" type="search" placeholder="搜索商品" autocomplete="off" />
      <button type="submit">搜索</button>
    </form>
    <nav class="nav" aria-label="主导航">
      {
        links.map((link) => (
          <a href={link.href} aria-current={pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href)) ? 'page' : undefined}>
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
  <script>
    const headerSearchForm = document.getElementById('headerSearchForm');
    const headerSearchInput = document.getElementById('headerSearchInput');

    headerSearchForm?.addEventListener('submit', (event) => {
      event.preventDefault();
      const query = headerSearchInput instanceof HTMLInputElement ? headerSearchInput.value.trim() : '';
      const params = new URLSearchParams();

      if (query) {
        params.set('q', query);
      }

      window.location.href = `/${params.toString() ? `?${params.toString()}` : ''}#products`;
    });
  </script>
</header>
