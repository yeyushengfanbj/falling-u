---
import type { CollectionEntry } from 'astro:content';
import { ArrowRight, CalendarDays } from 'lucide-astro';
import { categories } from '@/data/site';

type Props = {
  guide: CollectionEntry<'guides'>;
};

const { guide } = Astro.props;
const href = `/guides/${guide.id}/`;
const date = guide.data.publishDate.toLocaleDateString('zh-CN');
const category = categories.find((item) => item.slug === guide.data.category);
---

<article class="guide-card">
  <div class="guide-card-meta">
    <span>{category?.name ?? guide.data.category}</span>
    <span>·</span>
    <span><CalendarDays size={14} aria-hidden="true" /> {date}</span>
  </div>
  <h3><a href={href}>{guide.data.title}</a></h3>
  <p>{guide.data.description}</p>
  <div class="tag-row">
    {guide.data.tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>
  <p>
    <a class="text-link" href={href}>阅读全文 <ArrowRight size={16} aria-hidden="true" /></a>
  </p>
</article>
